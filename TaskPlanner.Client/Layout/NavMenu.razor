<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Mi Task Planner</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass p-3 text-white" @onclick="ToggleNavMenu" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">

    <div class="mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="fw-bold" style="font-size: 0.95rem;">@mesVisible.ToString("MMMM yyyy").ToUpper()</span>
            <div>
                <button class="btn btn-sm text-secondary p-0 me-2" @onclick="MesAnterior" @onclick:stopPropagation="true">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <button class="btn btn-sm text-secondary p-0" @onclick="MesSiguiente" @onclick:stopPropagation="true">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; text-align: center; font-size: 0.75rem; font-weight: bold;" class="text-secondary mb-2">
            <div>L</div><div>M</div><div>X</div><div>J</div><div>V</div><div>S</div><div>D</div>
        </div>

        <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; text-align: center; font-size: 0.8rem;">
            @foreach (var dia in ObtenerDiasDelMes(mesVisible))
            {
                bool esMesActual = dia.Month == mesVisible.Month;
                bool esHoy = dia.Date == DateTime.Today;

                <div class="p-1 rounded-circle d-flex align-items-center justify-content-center"
                     style="width: 28px; height: 28px; margin: 0 auto; cursor: pointer;
                                    @(esHoy ? "background-color: #0d6efd; color: white; font-weight: bold;" : "")
                                    @(!esMesActual && !esHoy ? "color: #6c757d; opacity: 0.5;" : "")
                                    @(esMesActual && !esHoy ? "color: #e9ecef;" : "")"
                     @onclick="() => AppState.CambiarFecha(dia.Date)">
                    @dia.Day
                </div>
            }
        </div>
    </div>

    <hr class="border-secondary opacity-25 my-4" />

    <div class="mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="fw-bold text-secondary" style="font-size: 0.75rem; letter-spacing: 1px;">MIS ETIQUETAS</span>
        </div>

        <div class="d-flex flex-column gap-2">
            @if (categorias != null)
            {
                @foreach (var cat in categorias)
                {
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="cat_@cat.Id"
                               checked="@(!AppState.CategoriasOcultas.Contains(cat.Id))"
                               @onchange="() => AppState.ToggleCategoria(cat.Id)" style="cursor:pointer;">
                        <label class="form-check-label text-light" for="cat_@cat.Id" style="font-size: 0.85rem; cursor:pointer;">
                            @cat.Nombre
                        </label>
                    </div>
                }
            }
        </div>
    </div>    
</div>

@code {
    [Inject] private TaskPlanner.Client.Services.TaskService Service { get; set; } = default!;
    [Inject] private TaskPlanner.Client.Services.AppState AppState { get; set; } = default!;

    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;
    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;

    private List<TaskPlanner.Client.Models.Categoria>? categorias;
    private DateTime mesVisible = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

    protected override async Task OnInitializedAsync()
    {
        categorias = await Service.GetCategorias();
        AppState.OnChange += StateHasChanged; // Escucha los cambios
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }

    private void MesAnterior() => mesVisible = mesVisible.AddMonths(-1);
    private void MesSiguiente() => mesVisible = mesVisible.AddMonths(1);

    private List<DateTime> ObtenerDiasDelMes(DateTime fechaReferencia)
    {
        var dias = new List<DateTime>();
        var primerDiaDelMes = new DateTime(fechaReferencia.Year, fechaReferencia.Month, 1);
        int offset = (int)primerDiaDelMes.DayOfWeek - (int)DayOfWeek.Monday;
        if (offset < 0) offset += 7;
        var primerDiaCuadricula = primerDiaDelMes.AddDays(-offset);
        for (int i = 0; i < 42; i++) dias.Add(primerDiaCuadricula.AddDays(i));
        return dias;
    }
}