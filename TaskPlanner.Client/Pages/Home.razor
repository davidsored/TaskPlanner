@page "/"
@using TaskPlanner.Client.Models;
@using TaskPlanner.Client.Services;
@inject TaskService Service;
@inject IJSRuntime JS;

<PageTitle>Dashboard Semanal</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-2 border-info">

    <div class="d-flex align-items-center gap-3">
        <div class="p-3 bg-info bg-opacity-10 border border-info rounded-end">
            <h4>Mi Semana</h4>
        </div>

        <button class="btn btn-outline-info rounded-end shadow-sm p-0"
                style="width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;"
                title="Ir a una fecha específica"
                onclick="document.getElementById('selectorFechaOculto').showPicker()">
            <i class="bi bi-calendar-week"></i>
        </button>

        <input type="date" id="selectorFechaOculto"
               style="position: absolute; width: 0; height: 0; border: none; padding: 0; visibility: hidden;"
               @onchange="IrAFecha" />
    </div>

    <div class="btn-group shadow-sm">
        <button class="btn btn-outline-info" @onclick="SemanaAnterior">
            <i class="bi bi-chevron-left"></i>Anterior
        </button>
        <button class="btn fw-bold text-white" style="background-color: skyblue;" @onclick="SemanaActual">
            Hoy
        </button>
        <button class="btn btn-outline-info" @onclick="SemanaSiguiente">
            Siguiente<i class="bi bi-chevron-right"></i>
        </button>
    </div>
</div>

<button type="button" class="btn btn-primary fab-button" data-bs-toggle="modal" data-bs-target="#modalTarea" @onclick="PrepararNuevaTarea">
    +
</button>

@if (tareas == null)
{
    <p>Cargando...</p>
}
else
{
    <div class="container-fluid">
        <div class="row">

            <div class="col border-end">
                <h5 class="text-center bg-light p-2">
                    Lunes <br />
                    <span style="font-size: 0.8rem; color: #666;">
                        @lunesDeEstaSemana.ToShortDateString()
                    </span>
                </h5>
                @foreach (var t in GetTareasPorDia(DayOfWeek.Monday))
                {
                    <div class="card mb-2 text-white shadow-sm"
                         style="background-color: @(t.ColorHex ?? "#ccc"); cursor: pointer;"
                         data-bs-toggle="modal" data-bs-target="#modalTarea"
                         @onclick="() => SeleccionarTarea(t)">
                        <div class="card-body p-2">
                            <strong>@t.Titulo</strong><br />
                            <small>@t.FechaInicio.ToString("HH:mm") - @t.FechaFin.ToString("HH:mm")</small>
                        </div>
                    </div>
                }
            </div>

            <div class="col border-end">
                <h5 class="text-center bg-light p-2">
                    Martes <br />
                    <span style="font-size: 0.8rem; color: #666">
						@lunesDeEstaSemana.AddDays(1).ToShortDateString()
                    </span>
                </h5>
                @foreach (var t in GetTareasPorDia(DayOfWeek.Tuesday))
                {
                    <div class="card mb-2 text-white shadow-sm"
                         style="background-color: @(t.ColorHex ?? "#ccc"); cursor: pointer;"
                         data-bs-toggle="modal" data-bs-target="#modalTarea"
                         @onclick="() => SeleccionarTarea(t)">
                        <div class="card-body p-2">
                            <strong>@t.Titulo</strong><br />
                            <small>@t.FechaInicio.ToString("HH:mm") - @t.FechaFin.ToString("HH:mm")</small>
                        </div>
                    </div>
                }
            </div>

            <div class="col border-end">
                <h5 class="text-center bg-light p-2">
                    Miércoles <br />
                    <span style="font-size: 0.8rem; color: #666">
                        @lunesDeEstaSemana.AddDays(2).ToShortDateString()
                    </span>
                </h5>
                @foreach (var t in GetTareasPorDia(DayOfWeek.Wednesday))
                {
                    <div class="card mb-2 text-white shadow-sm"
                         style="background-color: @(t.ColorHex ?? "#ccc"); cursor: pointer;"
                         data-bs-toggle="modal" data-bs-target="#modalTarea"
                         @onclick="() => SeleccionarTarea(t)">
                        <div class="card-body p-2">
                            <strong>@t.Titulo</strong><br />
                            <small>@t.FechaInicio.ToString("HH:mm") - @t.FechaFin.ToString("HH:mm")</small>
                        </div>
                    </div>
                }
            </div>

            <div class="col border-end">
                <h5 class="text-center bg-light p-2">
                    Jueves <br />
                    <span style="font-size: 0.8rem; color: #666">
                        @lunesDeEstaSemana.AddDays(3).ToShortDateString()
                    </span>
                </h5>
                @foreach (var t in GetTareasPorDia(DayOfWeek.Thursday))
                {
                    <div class="card mb-2 text-white shadow-sm"
                         style="background-color: @(t.ColorHex ?? "#ccc"); cursor: pointer;"
                         data-bs-toggle="modal" data-bs-target="#modalTarea"
                         @onclick="() => SeleccionarTarea(t)">
                        <div class="card-body p-2">
                            <strong>@t.Titulo</strong><br />
                            <small>@t.FechaInicio.ToString("HH:mm") - @t.FechaFin.ToString("HH:mm")</small>
                        </div>
                    </div>
                }
            </div>

            <div class="col">
                <h5 class="text-center bg-light p-2">
                    Viernes <br />
                    <span style="font-size: 0.8rem; color: #666">
                        @lunesDeEstaSemana.AddDays(4).ToShortDateString()
                    </span>
                </h5>
                @foreach (var t in GetTareasPorDia(DayOfWeek.Friday))
                {
                    <div class="card mb-2 text-white shadow-sm"
                         style="background-color: @(t.ColorHex ?? "#ccc"); cursor: pointer;"
                         data-bs-toggle="modal" data-bs-target="#modalTarea"
                         @onclick="() => SeleccionarTarea(t)">
                        <div class="card-body p-2">
                            <strong>@t.Titulo</strong><br />
                            <small>@t.FechaInicio.ToString("HH:mm") - @t.FechaFin.ToString("HH:mm")</small>
                        </div>
                    </div>
                }
            </div>

            <div class="col border-end">
                <h5 class="text-center bg-light p-2">
                    Sábado <br />
                    <span style="font-size: 0.8rem; color: #666">
                        @lunesDeEstaSemana.AddDays(5).ToShortDateString()
                    </span>
                </h5>
                @foreach (var t in GetTareasPorDia(DayOfWeek.Saturday))
                {
                    <div class="card mb-2 text-white shadow-sm"
                         style="background-color: @(t.ColorHex ?? "#ccc"); cursor: pointer;"
                         data-bs-toggle="modal" data-bs-target="#modalTarea"
                         @onclick="() => SeleccionarTarea(t)">
                        <div class="card-body p-2">
                            <strong>@t.Titulo</strong><br />
                            <small>@t.FechaInicio.ToString("HH:mm") - @t.FechaFin.ToString("HH:mm")</small>
                        </div>
                    </div>
                }
            </div>

            <div class="col border-end">
                <h5 class="text-center bg-light p-2">
                    Domingo <br />
                    <span style="font-size: 0.8rem; color: #666">
                        @lunesDeEstaSemana.AddDays(6).ToShortDateString()
                    </span>
                </h5>
                @foreach (var t in GetTareasPorDia(DayOfWeek.Sunday))
                {
                    <div class="card mb-2 text-white shadow-sm"
                         style="background-color: @(t.ColorHex ?? "#ccc"); cursor: pointer;"
                         data-bs-toggle="modal" data-bs-target="#modalTarea"
                         @onclick="() => SeleccionarTarea(t)">
                        <div class="card-body p-2">
                            <strong>@t.Titulo</strong><br />
                            <small>@t.FechaInicio.ToString("HH:mm") - @t.FechaFin.ToString("HH:mm")</small>
