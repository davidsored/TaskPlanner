@page "/"
@using TaskPlanner.Client.Models;
@using TaskPlanner.Client.Services;
@inject TaskService Service;
@inject IJSRuntime JS;
@inject TaskPlanner.Client.Services.AppState AppState
@implements IDisposable

<PageTitle>Dashboard Semanal</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-2 border-info">

    <div class="d-flex align-items-center gap-3">
        <div class="p-3 bg-info bg-opacity-10 border border-info rounded-end">
            <h4 class="mb-0">@(vistaActual == "Dia" ? "Mi Día" : vistaActual == "Semana" ? "Mi Semana" : "Mi Mes")</h4>
        </div>

        <button class="btn btn-outline-info rounded-end shadow-sm p-0"
                style="width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;"
                title="Ir a una fecha específica"
                onclick="document.getElementById('selectorFechaOculto').showPicker()">
            <i class="bi bi-calendar-week"></i>
        </button>

        <input type="date" id="selectorFechaOculto"
               style="position: absolute; width: 0; height: 0; border: none; padding: 0; visibility: hidden;"
               @onchange="IrAFecha" />
    </div>

    <div class="btn-group shadow-sm">
        <button class="btn @(vistaActual == "Dia" ? "btn-info text-white fw-bold" : "btn-outline-info")" @onclick="@(() => CambiarVista("Dia"))">Día</button>
        <button class="btn @(vistaActual == "Semana" ? "btn-info text-white fw-bold" : "btn-outline-info")" @onclick="@(() => CambiarVista("Semana"))">Semana</button>
        <button class="btn @(vistaActual == "Mes" ? "btn-info text-white fw-bold" : "btn-outline-info")" @onclick="@(() => CambiarVista("Mes"))">Mes</button>
    </div>

    <div class="btn-group shadow-sm">
        <button class="btn btn-outline-info" @onclick="NavegarAnterior">
            <i class="bi bi-chevron-left"></i>Anterior
        </button>
        <button class="btn fw-bold text-white" style="background-color: skyblue;" @onclick="NavegarHoy">
            Hoy
        </button>
        <button class="btn btn-outline-info" @onclick="NavegarSiguiente">
            Siguiente<i class="bi bi-chevron-right"></i>
        </button>
    </div>
</div>

<button type="button" class="btn btn-primary fab-button" data-bs-toggle="modal" data-bs-target="#modalTarea" @onclick="PrepararNuevaTarea">
    +
</button>

@if (tareas == null)
{
    <p>Cargando...</p>
}
else
{
    @if (vistaActual == "Semana")
    {
        <div class="d-flex flex-column border border-info border-opacity-25 shadow-sm rounded bg-white" style="height: 75vh; overflow-y: auto; overflow-x: hidden; position: relative;">

            <div class="d-flex border-bottom border-2 bg-light" style="position: sticky; top: 0; z-index: 10;">
                <div style="width: 60px; flex-shrink: 0;"></div>

                @foreach (var day in new[] { DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday, DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday })
                {
                    <div class="flex-grow-1 border-start text-center p-2" style="flex-basis: 0;">
                        <strong class="text-dark">@ObtenerNombreDia(day)</strong><br />
                        <span style="font-size: 0.8rem; color: #666;">
                            @GetFechaParaDia(day).ToShortDateString()
                        </span>
                    </div>
                }
            </div>

            <div class="d-flex" style="flex-grow: 1; position: relative;">

                <div style="width: 60px; flex-shrink: 0; background-color: #f8f9fa;">
                    @for (int i = 0; i < 24; i++)
                    {
                        <div style="height: 60px; position: relative;">
                            <span style="position: absolute; top: -10px; right: 8px; font-size: 0.75rem; color: #6c757d; font-weight: bold;">
                                @i.ToString("00"):00
                            </span>
                        </div>
                    }
                </div>

                <div class="d-flex flex-grow-1" style="position: relative;">
                    @foreach (var day in new[] { DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday, DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday })
                    {
                        <div class="flex-grow-1 border-start" style="position: relative; flex-basis: 0;">
                            @for (int i = 0; i < 24; i++)
                            {
                                <div style="height: 60px; border-bottom: 1px solid #e9ecef; box-sizing: border-box;"></div>
                            }

                            @{
                                var tareasDelDia = GetTareasPorDia(day).ToList();
                            }

                            @foreach (var t in tareasDelDia)
                            {
                                double topPx = (t.FechaInicio.Hour * 60) + t.FechaInicio.Minute;
                                double heightPx = (t.FechaFin - t.FechaInicio).TotalMinutes;
                                if (heightPx < 20) heightPx = 20;

                                var coordenadas = CalcularSolapamiento(t, tareasDelDia);

                                <div class="card position-absolute shadow-sm border-light text-white rounded-2"
                                     style="top: @(topPx)px; height: @(heightPx)px; left: @(coordenadas.Left); width: @(coordenadas.Width); background-color: @(t.ColorHex ?? "#0d6efd"); cursor: pointer; z-index: 5; overflow: hidden; opacity: 0.95;"
                                     data-bs-toggle="modal" data-bs-target="#modalTarea"
                                     @onclick="() => SeleccionarTarea(t, GetFechaParaDia(day))">

                                    <div class="card-body p-1 lh-1">
                                        <div style="font-size: 0.75rem; font-weight: bold; text-overflow: ellipsis; white-space: nowrap; overflow: hidden;">@t.Titulo</div>
                                        <div style="font-size: 0.65rem; margin-top: 2px;">@t.FechaInicio.ToString("HH:mm")</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else if (vistaActual == "Dia")
    {
        <div class="d-flex flex-column border border-info border-opacity-25 shadow-sm rounded bg-white" style="height: 75vh; overflow-y: auto; overflow-x: hidden; position: relative;">

            <div class="d-flex border-bottom border-2 bg-light" style="position: sticky; top: 0; z-index: 10;">
                <div style="width: 60px; flex-shrink: 0;"></div>
                <div class="flex-grow-1 border-start text-center p-2">
                    <strong class="text-dark fs-5">@ObtenerNombreDia(diaVisible.DayOfWeek)</strong><br />
                    <span style="font-size: 1rem; color: #666;">@diaVisible.ToShortDateString()</span>
                </div>
            </div>

            <div class="d-flex" style="flex-grow: 1; position: relative;">
                <div style="width: 60px; flex-shrink: 0; background-color: #f8f9fa;">
                    @for (int i = 0; i < 24; i++)
                    {
                        <div style="height: 60px; position: relative;">
                            <span style="position: absolute; top: -10px; right: 8px; font-size: 0.75rem; color: #6c757d; font-weight: bold;">@i.ToString("00"):00</span>
                        </div>
                    }
                </div>

                <div class="flex-grow-1 border-start" style="position: relative;">
                    @for (int i = 0; i < 24; i++)
                    {
                        <div style="height: 60px; border-bottom: 1px solid #e9ecef; box-sizing: border-box;"></div>
                    }

                    @{
                        var tareasDelDiaVisible = GetTareasParaFechaExacta(diaVisible).ToList();
                    }

                    @foreach (var t in tareasDelDiaVisible)
                    {
                        double topPx = (t.FechaInicio.Hour * 60) + t.FechaInicio.Minute;
                        double heightPx = (t.FechaFin - t.FechaInicio).TotalMinutes;
                        if (heightPx < 20) heightPx = 20;
                        var coordenadas = CalcularSolapamiento(t, tareasDelDiaVisible);

                        <div class="card position-absolute shadow border-light text-white rounded-3"
                             style="top: @(topPx)px; height: @(heightPx)px; left: @(coordenadas.Left); width: @(coordenadas.Width); background-color: @(t.ColorHex ?? "#0d6efd"); cursor: pointer; z-index: 5; overflow: hidden; opacity: 0.95;"
                             data-bs-toggle="modal" data-bs-target="#modalTarea"
                             @onclick="() => SeleccionarTarea(t, diaVisible)">

                            <div class="card-body p-2 lh-1">
                                <div style="font-size: 0.9rem; font-weight: bold; text-overflow: ellipsis; white-space: nowrap; overflow: hidden;">@t.Titulo</div>
                                <div style="font-size: 0.8rem; margin-top: 4px;">@t.FechaInicio.ToString("HH:mm") - @t.FechaFin.ToString("HH:mm")</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else if (vistaActual == "Mes")
    {
        <div class="border border-info border-opacity-25 shadow-sm rounded bg-white p-2" style="height: 75vh; display: flex; flex-direction: column;">

            <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px;" class="mb-2 text-center fw-bold text-dark border-bottom pb-2">
                <div>Lunes</div><div>Martes</div><div>Miércoles</div><div>Jueves</div><div>Viernes</div><div>Sábado</div><div>Domingo</div>
            </div>

            <div style="display: grid; grid-template-columns: repeat(7, 1fr); grid-template-rows: repeat(6, 1fr); gap: 4px; flex-grow: 1;">
                @{
                    var diasMes = ObtenerDiasDelMes(diaVisible);
                    foreach (var dia in diasMes)
                    {
                        bool esMesActual = dia.Month == diaVisible.Month;
                        bool esHoy = dia.Date == DateTime.Today;

                        <div class="border rounded p-1 d-flex flex-column" style="background-color: @(esMesActual ? "#ffffff" : "#f8f9fa"); overflow: hidden;">

                            <div class="text-end mb-1">
                                <span class="badge @(esHoy ? "bg-primary" : "text-dark bg-transparent")"
                                      style="font-size: 0.85rem; @(!esHoy && !esMesActual ? "opacity: 0.4;" : "")">
                                    @dia.Day
                                </span>
                            </div>

                            <div style="overflow-y: auto; flex-grow: 1; padding-right: 2px;">
                                @{
                                    var tareasDia = GetTareasParaFechaExacta(dia).ToList();
                                }
                                @foreach (var t in tareasDia)
                                {
                                    <div class="rounded mb-1 px-1 text-white shadow-sm"
                                         style="font-size: 0.7rem; background-color: @(t.ColorHex ?? "#0d6efd"); cursor: pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; line-height: 1.5;"
                                         data-bs-toggle="modal" data-bs-target="#modalTarea"
                                         @onclick="() => SeleccionarTarea(t, dia)"
                                         title="@t.Titulo">
                                        <strong>@t.FechaInicio.ToString("HH:mm")</strong> @t.Titulo
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
}

<div class="modal fade" id="modalTarea" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Nueva Tarea</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <EditForm Model=@nuevaTarea OnValidSubmit=@CrearTarea>
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label>Título</label>
                        <InputText class="form-control" @bind-Value="nuevaTarea.Titulo" />
                        <ValidationMessage For="@(() => nuevaTarea.Titulo)" />
                    </div>

                    <div class="mb-3 bg-light p-3 rounded border shadow-sm">
                        <label class="form-label fw-bold">Horario</label>
                        <div class="row g-2">
                            <div class="col-12">
                                <label class="small text-muted">Día de la tarea</label>
                                <InputDate class="form-control form-control-sm" @bind-Value="nuevaTarea.FechaInicio" />
                            </div>
                            <div class="col-6">
                                <label class="small text-muted">Hora Inicio</label>
                                <input type="time" class="form-control form-control-sm"
                                       value="@nuevaTarea.FechaInicio.ToString("HH:mm")"
                                       @onchange="SetHoraInicio" />
                            </div>
                            <div class="col-6">
                                <label class="small text-muted">Hora Fin</label>
                                <input type="time" class="form-control form-control-sm"
                                       value="@nuevaTarea.FechaFin.ToString("HH:mm")"
                                       @onchange="SetHoraFin" />
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-3 p-3 border rounded shadow-sm bg-light">
                        <label class="form-label fw-bold">Repetir en otro días</label>
                        <p class="small text-muted mb-2">Marca los días de la semana en los que quieres que se repita esta tarea.</p>

                        <div class="d-flex gap-2 justify-content-between">
                            @foreach (var dia in diasRepeticion)
                            {
                                var diaActual = dia;
                                <div @key="diaActual.Nombre">
                                    <input type="checkbox" class="btn-check" id="btncheck-@diaActual.Nombre" autocomplete="off"
                                           checked="@diaActual.Seleccionado"
                                           @onchange="@((ChangeEventArgs e) => diaActual.Seleccionado = (bool)(e.Value ?? false))">
                                    <label class="btn btn-outline-info rounded-circle" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; font-weight: bold;" for="btncheck-@diaActual.Nombre">
                                        @diaActual.Nombre
                                    </label>
                                </div>
                            }
                        </div>
                    </div>                    

                    <div class="mb-3">
                        <label>Categoría</label>
                        <div class="input-group">
                            <InputSelect class="form-select" @bind-Value="nuevaTarea.CategoriaId">
                                <option value="0">-- Selecciona --</option>
                                @if (categorias != null)
                                {
                                    @foreach (var cat in categorias)
                                    {
                                        <option value="@cat.Id">@cat.Nombre</option>
                                    }
                                }
                            </InputSelect>
                            <button class="btn btn-outline-secondary" type="button" @onclick="NuevaCategoria" title="Crear nueva categoría">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>

                        @if (mostrarNuevaCat)
                        {
                            <div class="input-group mt-2 shadow-sm">
                                <input type="text" class="form-control form-control-sm" placeholder="Nombre de la nueva categoría..." @bind="nombreCatNueva" />
                                <button class="btn btn-sm btn-primary" type="button" @onclick="GuardarCategoria">
                                    Guardar Categoría
                                </button>
                            </div>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Color (Obligatorio)</label>
                        <div class="d-flex gap-2 p-2 border rounded align-items-center">
                            @foreach (var color in new[] { "#0d6efd", "#ee4444", "#22cc66", "#ff8822", "#aa66ff", "#22cccc" })
                            {
                                <button type="button"
                                        class="rounded-circle border-0 shadow-sm"
                                        style="width: 30px; height: 30px; background-color: @color; cursor: pointer; transform: scale(@(nuevaTarea.ColorHex == color ? 1.2 : 1)); border: 2px solid @(nuevaTarea.ColorHex == color ? "#333" : "transparent")"
                                        @onclick="() => nuevaTarea.ColorHex = color">
                                </button>
                            }
                            <div class="ms-2 border-start ps-3">
                                <input type="color"
                                       class="border-0 shadow-sm"
                                       style="width: 35px; height: 35px; cursor: pointer; padding: 0; background: none; border-radius: 4px;"
                                       title="Elegir otro color"
                                       @bind="nuevaTarea.ColorHex" />
                            </div>
                        </div>
                        <div class="text-danger small mt-1">
                            <ValidationMessage For="@(() => nuevaTarea.ColorHex)" />
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        @if (nuevaTarea.Id != 0)
                        {
                            @if (nuevaTarea.EsRecurrente)
                            {
                                <div class="d-flex flex-column gap-2 w-50">
                                    <button type="button" class="btn btn-outline-danger shadow-sm" @onclick="EliminarSoloEstaOcurrencia">
                                        <i class="bi bi-calendar-x"></i> Borrar solo este día
                                    </button>
                                    <button type="button" class="btn btn-danger shadow-sm" @onclick="EliminarTarea">
                                        <i class="bi bi-trash"></i> Borrar toda la serie
                                    </button>
                                </div>
                            }
                            else
                            {
                                <button type="button" class="btn btn-danger w-50 shadow-sm" @onclick="EliminarTarea">
                                    <i class="bi bi-trash"></i> Borrar
                                </button>
                            }
                        }
                        <button type="submit" class="btn btn-success flex-grow-1 shadow-sm">
                            Guardar Tarea
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Tarea>? tareas;
    private List<Categoria>? categorias;
    private Tarea nuevaTarea = new Tarea { FechaInicio = DateTime.Today };
    private DateTime lunesDeEstaSemana;
    private bool mostrarNuevaCat = false;
    private string nombreCatNueva = "";
    private DateTime? fechaOcurrenciaSeleccionada;

    protected override async Task OnInitializedAsync()
    {
        tareas = await Service.GetTareas();
        categorias = await Service.GetCategorias();

        diaVisible = AppState.FechaSeleccionada;
        CalcularInicioSemana();

        AppState.OnChange += SincronizarConEstado;
    }

    private void SincronizarConEstado()
    {
        if (diaVisible.Date != AppState.FechaSeleccionada.Date)
        {
            diaVisible = AppState.FechaSeleccionada;
            CalcularInicioSemana();
        }
        InvokeAsync(StateHasChanged); 
    }

    public void Dispose()
    {
        AppState.OnChange -= SincronizarConEstado;
    }

    private void CalcularInicioSemana()
    {
        int diasHastaLunes = ((int)diaVisible.DayOfWeek - (int)DayOfWeek.Monday);
        if (diasHastaLunes < 0) diasHastaLunes += 7;
        lunesDeEstaSemana = diaVisible.AddDays(-diasHastaLunes);
    }

    private IEnumerable<Tarea> GetTareasPorDia(DayOfWeek dia)
    {
        if (tareas == null) return new List<Tarea>();

        int diasASumar = ((int)dia - (int)DayOfWeek.Monday);
        if (diasASumar < 0) diasASumar += 7;
        DateTime fechaDeLaColumna = lunesDeEstaSemana.AddDays(diasASumar).Date;

        var tareasNormales = tareas.Where(t => !t.EsRecurrente && t.FechaInicio.Date == fechaDeLaColumna);

        string letraDelDia = ObtenerLetraDia(dia);

        string fechaStr = fechaDeLaColumna.ToString("yyyy-MM-dd");

        var tareasRecurrentes = tareas.Where(t =>
            t.EsRecurrente &&
            t.PatronDias != null &&
            t.PatronDias.Contains(letraDelDia) &&
            t.FechaInicio.Date <= fechaDeLaColumna &&
            (t.FechaFinRecurrencia == null || t.FechaFinRecurrencia.Value.Date >= fechaDeLaColumna) &&
            (t.FechasExcluidas == null || !t.FechasExcluidas.Contains(fechaStr))
        );

        return tareasNormales.Concat(tareasRecurrentes)
            .Where(t => !AppState.CategoriasOcultas.Contains(t.CategoriaId ?? 0))
            .OrderBy(t => t.FechaInicio.TimeOfDay);
    }

    private string ObtenerLetraDia(DayOfWeek dia)
    {
        return dia switch
        {
            DayOfWeek.Monday => "L",
            DayOfWeek.Tuesday => "M",
            DayOfWeek.Wednesday => "X",
            DayOfWeek.Thursday => "J",
            DayOfWeek.Friday => "V",
            DayOfWeek.Saturday => "S",
            DayOfWeek.Sunday => "D",
            _ => ""
        };
    }

    private async Task CrearTarea()
    {
        var diasMarcados = diasRepeticion.Where(d => d.Seleccionado).ToList();

        if (diasMarcados.Any())
        {
            nuevaTarea.EsRecurrente = true;
            nuevaTarea.PatronDias = string.Join(",", diasMarcados.Select(d => d.Nombre));

            if (nuevaTarea.FechaFinRecurrencia == null)
            {
                nuevaTarea.FechaFinRecurrencia = nuevaTarea.FechaInicio.AddYears(1);
            }
        }
        else
        {
            nuevaTarea.EsRecurrente = false;
            nuevaTarea.PatronDias = null;
            nuevaTarea.FechaFinRecurrencia = null;
        }

        await Service.SaveTarea(nuevaTarea);

        nuevaTarea = new Tarea { FechaInicio = DateTime.Today, FechaFin = DateTime.Today.AddHours(1) };
        foreach (var dia in diasRepeticion) dia.Seleccionado = false;

        tareas = await Service.GetTareas();

        await JS.InvokeVoidAsync("eval", "document.querySelector('#modalTarea .btn-close').click()");
    }

    private void PrepararNuevaTarea()
    {
        nuevaTarea = new Tarea { FechaInicio = DateTime.Today, FechaFin = DateTime.Today.AddHours(1) };
        foreach (var dia in diasRepeticion) dia.Seleccionado = false;
    }

    private async Task SeleccionarTarea(Tarea t, DateTime fechaOcurrencia)
    {
        fechaOcurrenciaSeleccionada = fechaOcurrencia;

        nuevaTarea = new Tarea
        {
            Id = t.Id,
            Titulo = t.Titulo,
            Descripcion = t.Descripcion,
            FechaInicio = t.FechaInicio,
            FechaFin = t.FechaFin,
            ColorHex = t.ColorHex,
            CategoriaId = t.CategoriaId,
            EsRecurrente = t.EsRecurrente,
            PatronDias = t.PatronDias,
            FechaFinRecurrencia = t.FechaFinRecurrencia,
            FechasExcluidas = t.FechasExcluidas // NUEVO
        };

        foreach (var dia in diasRepeticion)
        {
            dia.Seleccionado = t.EsRecurrente && !string.IsNullOrEmpty(t.PatronDias) && t.PatronDias.Contains(dia.Nombre);
        }
    }

    private async Task EliminarTarea()
    {
        await Service.DeleteTarea(nuevaTarea.Id);

        tareas = await Service.GetTareas();

        await JS.InvokeVoidAsync("eval", "document.querySelector('#modalTarea .btn-close').click()");
    }

    private async Task EliminarSoloEstaOcurrencia()
    {
        if (fechaOcurrenciaSeleccionada.HasValue)
        {
            string fechaStr = fechaOcurrenciaSeleccionada.Value.ToString("yyyy-MM-dd");

            // La añadimos a la lista negra
            if (string.IsNullOrEmpty(nuevaTarea.FechasExcluidas))
            {
                nuevaTarea.FechasExcluidas = fechaStr;
            }
            else if (!nuevaTarea.FechasExcluidas.Contains(fechaStr))
            {
                nuevaTarea.FechasExcluidas += "," + fechaStr;
            }

            await Service.SaveTarea(nuevaTarea);

            tareas = await Service.GetTareas();
            await JS.InvokeVoidAsync("eval", "document.querySelector('#modalTarea .btn-close').click()");
        }
    }

    private void SetHoraInicio(ChangeEventArgs e)
    {
        if (TimeSpan.TryParse(e.Value?.ToString(), out var time))
        {
            nuevaTarea.FechaInicio = nuevaTarea.FechaInicio.Date.Add(time);
        }
    }

    private void SetHoraFin(ChangeEventArgs e)
    {
        if (TimeSpan.TryParse(e.Value?.ToString(), out var time))
        {
            nuevaTarea.FechaFin = nuevaTarea.FechaInicio.Date.Add(time);
        }
    }

    private void NuevaCategoria()
    {
        mostrarNuevaCat = !mostrarNuevaCat;
        nombreCatNueva = "";
    }

    private async Task GuardarCategoria()
    {
        if (!string.IsNullOrWhiteSpace(nombreCatNueva))
        {
            var nuevaCat = new Categoria { Nombre = nombreCatNueva };
            await Service.SaveCategorias(nuevaCat);

            categorias = await Service.GetCategorias();

            var catCreada = categorias.LastOrDefault(c => c.Nombre == nombreCatNueva);
            if (catCreada != null)
            {
                nuevaTarea.CategoriaId = catCreada.Id;
            }

            mostrarNuevaCat = false;
            nombreCatNueva = "";
        }
    }

    private void NavegarAnterior()
    {
        if (vistaActual == "Semana") lunesDeEstaSemana = lunesDeEstaSemana.AddDays(-7);
        else if (vistaActual == "Dia") diaVisible = diaVisible.AddDays(-1);
        else if (vistaActual == "Mes") diaVisible = diaVisible.AddMonths(-1);
    }

    private void NavegarSiguiente()
    {
        if (vistaActual == "Semana") lunesDeEstaSemana = lunesDeEstaSemana.AddDays(7);
        else if (vistaActual == "Dia") diaVisible = diaVisible.AddDays(1);
        else if (vistaActual == "Mes") diaVisible = diaVisible.AddMonths(1);
    }

    private void NavegarHoy()
    {
        CalcularInicioSemana();
        diaVisible = DateTime.Today;
    }

    public class DiaRepeticion
    {
        public string Nombre { get; set; } = "";
        public DayOfWeek Dia { get; set; }
        public bool Seleccionado { get; set; }
    }

    private List<DiaRepeticion> diasRepeticion = new()
    {
        new DiaRepeticion {Nombre = "L", Dia = DayOfWeek.Monday},
        new DiaRepeticion {Nombre = "M", Dia = DayOfWeek.Tuesday},
        new DiaRepeticion {Nombre = "X", Dia = DayOfWeek.Wednesday},
        new DiaRepeticion {Nombre = "J", Dia = DayOfWeek.Thursday},
        new DiaRepeticion {Nombre = "V", Dia = DayOfWeek.Friday},
        new DiaRepeticion {Nombre = "S", Dia = DayOfWeek.Saturday},
        new DiaRepeticion {Nombre = "D", Dia = DayOfWeek.Sunday},
    };

    private void IrAFecha(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out DateTime fechaSeleccionada))
        {
            int diasHastaLunes = ((int)fechaSeleccionada.DayOfWeek - (int)DayOfWeek.Monday);
            if (diasHastaLunes < 0) diasHastaLunes += 7;
            lunesDeEstaSemana = fechaSeleccionada.AddDays(-diasHastaLunes);

            diaVisible = fechaSeleccionada;
        }
    }

    private List<DateTime> ObtenerDiasDelMes(DateTime fechaReferencia)
    {
        var dias = new List<DateTime>();
        var primerDiaDelMes = new DateTime(fechaReferencia.Year, fechaReferencia.Month, 1);

        int offset = (int)primerDiaDelMes.DayOfWeek - (int)DayOfWeek.Monday;
        if (offset < 0) offset += 7; 

        var primerDiaCuadricula = primerDiaDelMes.AddDays(-offset);

        for (int i = 0; i < 42; i++)
        {
            dias.Add(primerDiaCuadricula.AddDays(i));
        }

        return dias;
    }

    private string ObtenerNombreDia(DayOfWeek dia)
    {
        return dia switch
        {
            DayOfWeek.Monday => "Lunes",
            DayOfWeek.Tuesday => "Martes",
            DayOfWeek.Wednesday => "Miércoles",
            DayOfWeek.Thursday => "Jueves",
            DayOfWeek.Friday => "Viernes",
            DayOfWeek.Saturday => "Sábado",
            DayOfWeek.Sunday => "Domingo",
            _ => ""
        };
    }

    private DateTime GetFechaParaDia(DayOfWeek dia)
    {
        int diasASumar = ((int)dia - (int)DayOfWeek.Monday);
        if (diasASumar < 0) diasASumar += 7;
        return lunesDeEstaSemana.AddDays(diasASumar);
    }

    private (string Width, string Left) CalcularSolapamiento(Tarea tareaActual, List<Tarea> todasLasTareasDelDia)
    {
        var solapadas = todasLasTareasDelDia.Where(t =>
            t.FechaInicio.TimeOfDay < tareaActual.FechaFin.TimeOfDay &&
            t.FechaFin.TimeOfDay > tareaActual.FechaInicio.TimeOfDay)
            .OrderBy(t => t.FechaInicio.TimeOfDay)
            .ThenBy(t => t.Id)
            .ToList();

        if (solapadas.Count <= 1)
        {
            return ("calc(100% - 4px)", "2px");
        }

        int posicion = solapadas.IndexOf(tareaActual);
        double anchoPorcentaje = 100.0 / solapadas.Count;
        double izquierdaPorcentaje = posicion * anchoPorcentaje;

        string anchoCss = anchoPorcentaje.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
        string izquierdaCss = izquierdaPorcentaje.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);

        return ($"calc({anchoCss}% - 2px)", $"calc({izquierdaCss}%)");
    }

    private string vistaActual = "Semana"; 
    private DateTime diaVisible = DateTime.Today; 

    private void CambiarVista(string nuevaVista)
    {
        vistaActual = nuevaVista;
    }

    private IEnumerable<Tarea> GetTareasParaFechaExacta(DateTime fecha)
    {
        if (tareas == null) return new List<Tarea>();

        var tareasNormales = tareas.Where(t => !t.EsRecurrente && t.FechaInicio.Date == fecha.Date);
        string letraDelDia = ObtenerLetraDia(fecha.DayOfWeek);

        string fechaStr = fecha.ToString("yyyy-MM-dd");

        var tareasRecurrentes = tareas.Where(t =>
            t.EsRecurrente &&
            t.PatronDias != null &&
            t.PatronDias.Contains(letraDelDia) &&
            t.FechaInicio.Date <= fecha.Date &&
            (t.FechaFinRecurrencia == null || t.FechaFinRecurrencia.Value.Date >= fecha.Date) &&
            (t.FechasExcluidas == null || !t.FechasExcluidas.Contains(fechaStr)) 
        );

        return tareasNormales.Concat(tareasRecurrentes)
            .Where(t => !AppState.CategoriasOcultas.Contains(t.CategoriaId ?? 0))
            .OrderBy(t => t.FechaInicio.TimeOfDay);
    }
