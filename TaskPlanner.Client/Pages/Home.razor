}

<div class="modal fade" id="modalTarea" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Nueva Tarea</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <EditForm Model=@nuevaTarea OnValidSubmit=@CrearTarea>
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label>Título</label>
                        <InputText class="form-control" @bind-Value="nuevaTarea.Titulo" />
                        <ValidationMessage For="@(() => nuevaTarea.Titulo)" />
                    </div>

                    <div class="mb-3 bg-light p-3 rounded border shadow-sm">
                        <label class="form-label fw-bold">Horario</label>
                        <div class="row g-2">
                            <div class="col-12">
                                <label class="small text-muted">Día de la tarea</label>
                                <InputDate class="form-control form-control-sm" @bind-Value="nuevaTarea.FechaInicio" />
                            </div>
                            <div class="col-6">
                                <label class="small text-muted">Hora Inicio</label>
                                <input type="time" class="form-control form-control-sm"
                                       value="@nuevaTarea.FechaInicio.ToString("HH:mm")"
                                       @onchange="SetHoraInicio" />
                            </div>
                            <div class="col-6">
                                <label class="small text-muted">Hora Fin</label>
                                <input type="time" class="form-control form-control-sm"
                                       value="@nuevaTarea.FechaFin.ToString("HH:mm")"
                                       @onchange="SetHoraFin" />
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-3 p-3 border rounded shadow-sm bg-light">
                        <label class="form-label fw-bold">Repetir en otro días</label>
                        <p class="small text-muted mb-2">Marca los días de la semana en los que quieres que se repita esta tarea.</p>

                        <div class="d-flex gap-2 justify-content-between">
                            @foreach (var dia in diasRepeticion)
                            {
                                var diaActual = dia;
                                <div @key="diaActual.Nombre">
                                    <input type="checkbox" class="btn-check" id="btncheck-@diaActual.Nombre" autocomplete="off"
                                           checked="@diaActual.Seleccionado"
                                           @onchange="@((ChangeEventArgs e) => diaActual.Seleccionado = (bool)(e.Value ?? false))">
                                    <label class="btn btn-outline-info rounded-circle" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; font-weight: bold;" for="btncheck-@diaActual.Nombre">
                                        @diaActual.Nombre
                                    </label>
                                </div>
                            }
                        </div>
                    </div>                    

                    <div class="mb-3">
                        <label>Categoría</label>
                        <div class="input-group">
                            <InputSelect class="form-select" @bind-Value="nuevaTarea.CategoriaId">
                                <option value="0">-- Selecciona --</option>
                                @if (categorias != null)
                                {
                                    @foreach (var cat in categorias)
                                    {
                                        <option value="@cat.Id">@cat.Nombre</option>
                                    }
                                }
                            </InputSelect>
                            <button class="btn btn-outline-secondary" type="button" @onclick="NuevaCategoria" title="Crear nueva categoría">
                                <i class="bi bi-plus-lg">+</i>
                            </button>
                        </div>

                        @if (mostrarNuevaCat)
                        {
                            <div class="input-group mt-2 shadow-sm">
                                <input type="text" class="form-control form-control-sm" placeholder="Nombre de la nueva categoría..." @bind="nombreCatNueva" />
                                <button class="btn btn-sm btn-primary" type="button" @onclick="GuardarCategoria">
                                    Guardar Categoría
                                </button>
                            </div>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Color (Obligatorio)</label>
                        <div class="d-flex gap-2 p-2 border rounded align-items-center">
                            @foreach (var color in new[] { "#0d6efd", "#ee4444", "#22cc66", "#ff8822", "#aa66ff", "#22cccc" })
                            {
                                <button type="button"
                                        class="rounded-circle border-0 shadow-sm"
                                        style="width: 30px; height: 30px; background-color: @color; cursor: pointer; transform: scale(@(nuevaTarea.ColorHex == color ? 1.2 : 1)); border: 2px solid @(nuevaTarea.ColorHex == color ? "#333" : "transparent")"
                                        @onclick="() => nuevaTarea.ColorHex = color">
                                </button>
                            }
                            <div class="ms-2 border-start ps-3">
                                <input type="color"
                                       class="border-0 shadow-sm"
                                       style="width: 35px; height: 35px; cursor: pointer; padding: 0; background: none; border-radius: 4px;"
                                       title="Elegir otro color"
                                       @bind="nuevaTarea.ColorHex" />
                            </div>
                        </div>
                        <div class="text-danger small mt-1">
                            <ValidationMessage For="@(() => nuevaTarea.ColorHex)" />
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        @if (nuevaTarea.Id != 0)
                        {
                            <button type="button" class="btn btn-danger w-50 shadow-sm" @onclick="EliminarTarea">
                                <i class="bi bi-trash"></i> Borrar
                            </button>
                        }
                        <button type="submit" class="btn btn-success flex-grow-1 shadow-sm">
                            Guardar Tarea
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Tarea>? tareas;
    private List<Categoria>? categorias;
    private Tarea nuevaTarea = new Tarea { FechaInicio = DateTime.Today };
    private DateTime lunesDeEstaSemana;
    private bool mostrarNuevaCat = false;
    private string nombreCatNueva = "";

    protected override async Task OnInitializedAsync()
    {
        tareas = await Service.GetTareas();
        categorias = await Service.GetCategorias();

        CalcularInicioSemana();
    }

    private void CalcularInicioSemana()
    {
        DateTime hoy = DateTime.Today;

        int diasHastaLunes = ((int)hoy.DayOfWeek - (int)DayOfWeek.Monday);

        if (diasHastaLunes < 0) diasHastaLunes += 7;

        lunesDeEstaSemana = hoy.AddDays(-diasHastaLunes);
    }

    private IEnumerable<Tarea> GetTareasPorDia(DayOfWeek dia)
    {
        if (tareas == null) return new List<Tarea>();

        int diasASumar = ((int)dia - (int)DayOfWeek.Monday);
        if (diasASumar < 0) diasASumar += 7;
        DateTime fechaDeLaColumna = lunesDeEstaSemana.AddDays(diasASumar).Date;

        var tareasNormales = tareas.Where(t => !t.EsRecurrente && t.FechaInicio.Date == fechaDeLaColumna);

        string letraDelDia = ObtenerLetraDia(dia);

        var tareasRecurrentes = tareas.Where(t =>
            t.EsRecurrente &&
            t.PatronDias != null &&
            t.PatronDias.Contains(letraDelDia) && 
            t.FechaInicio.Date <= fechaDeLaColumna && 
            (t.FechaFinRecurrencia == null || t.FechaFinRecurrencia.Value.Date >= fechaDeLaColumna) 
        );

        return tareasNormales.Concat(tareasRecurrentes).OrderBy(t => t.FechaInicio.TimeOfDay);
    }

    private string ObtenerLetraDia(DayOfWeek dia)
    {
        return dia switch
        {
            DayOfWeek.Monday => "L",
            DayOfWeek.Tuesday => "M",
            DayOfWeek.Wednesday => "X",
            DayOfWeek.Thursday => "J",
            DayOfWeek.Friday => "V",
            DayOfWeek.Saturday => "S",
            DayOfWeek.Sunday => "D",
            _ => ""
        };
    }

    private async Task CrearTarea()
    {
        var diasMarcados = diasRepeticion.Where(d => d.Seleccionado).ToList();

        if (diasMarcados.Any())
        {
            nuevaTarea.EsRecurrente = true;
            nuevaTarea.PatronDias = string.Join(",", diasMarcados.Select(d => d.Nombre));

            if (nuevaTarea.FechaFinRecurrencia == null)
            {
                nuevaTarea.FechaFinRecurrencia = nuevaTarea.FechaInicio.AddYears(1);
            }
        }
        else
        {
            nuevaTarea.EsRecurrente = false;
            nuevaTarea.PatronDias = null;
            nuevaTarea.FechaFinRecurrencia = null;
        }

        await Service.SaveTarea(nuevaTarea);

        nuevaTarea = new Tarea { FechaInicio = DateTime.Today, FechaFin = DateTime.Today.AddHours(1) };
        foreach (var dia in diasRepeticion) dia.Seleccionado = false;

        tareas = await Service.GetTareas();

        await JS.InvokeVoidAsync("eval", "document.querySelector('#modalTarea .btn-close').click()");
    }

    private void PrepararNuevaTarea()
    {
        nuevaTarea = new Tarea { FechaInicio = DateTime.Today, FechaFin = DateTime.Today.AddHours(1) };
        foreach (var dia in diasRepeticion) dia.Seleccionado = false;
    }

    private async Task SeleccionarTarea(Tarea t)
    {
        nuevaTarea = new Tarea
        {
            Id = t.Id,
            Titulo = t.Titulo,
            Descripcion = t.Descripcion,
            FechaInicio = t.FechaInicio,
            FechaFin = t.FechaFin,
            ColorHex = t.ColorHex,
            CategoriaId = t.CategoriaId,
            EsRecurrente = t.EsRecurrente,
			PatronDias = t.PatronDias,
			FechaFinRecurrencia = t.FechaFinRecurrencia
		};

        foreach(var dia in diasRepeticion)
        {
            dia.Seleccionado = t.EsRecurrente && !string.IsNullOrEmpty(t.PatronDias) && t.PatronDias.Contains(dia.Nombre);
        }
    }

    private async Task EliminarTarea()
    {
        await Service.DeleteTarea(nuevaTarea.Id);

        tareas = await Service.GetTareas();

        await JS.InvokeVoidAsync("eval", "document.querySelector('#modalTarea .btn-close').click()");
    }

    private void SetHoraInicio(ChangeEventArgs e)
    {
        if (TimeSpan.TryParse(e.Value?.ToString(), out var time))
        {
            nuevaTarea.FechaInicio = nuevaTarea.FechaInicio.Date.Add(time);
        }
    }

    private void SetHoraFin(ChangeEventArgs e)
    {
        if (TimeSpan.TryParse(e.Value?.ToString(), out var time))
        {
            nuevaTarea.FechaFin = nuevaTarea.FechaInicio.Date.Add(time);
        }
    }

    private void NuevaCategoria()
    {
        mostrarNuevaCat = !mostrarNuevaCat;
        nombreCatNueva = "";
    }

    private async Task GuardarCategoria()
    {
        if (!string.IsNullOrWhiteSpace(nombreCatNueva))
        {
            var nuevaCat = new Categoria { Nombre = nombreCatNueva };
            await Service.SaveCategorias(nuevaCat);

            categorias = await Service.GetCategorias();

            var catCreada = categorias.LastOrDefault(c => c.Nombre == nombreCatNueva);
            if (catCreada != null)
            {
                nuevaTarea.CategoriaId = catCreada.Id;
            }

            mostrarNuevaCat = false;
            nombreCatNueva = "";
        }
    }

    private void SemanaAnterior()
    {
        lunesDeEstaSemana = lunesDeEstaSemana.AddDays(-7);
    }

    private void SemanaSiguiente()
    {
        lunesDeEstaSemana = lunesDeEstaSemana.AddDays(7);
    }

    private void SemanaActual()
    {
        CalcularInicioSemana();
    }

    public class DiaRepeticion
    {
        public string Nombre { get; set; } = "";
        public DayOfWeek Dia { get; set; }
        public bool Seleccionado { get; set; }
    }

    private List<DiaRepeticion> diasRepeticion = new()
    {
        new DiaRepeticion {Nombre = "L", Dia = DayOfWeek.Monday},
        new DiaRepeticion {Nombre = "M", Dia = DayOfWeek.Tuesday},
        new DiaRepeticion {Nombre = "X", Dia = DayOfWeek.Wednesday},
        new DiaRepeticion {Nombre = "J", Dia = DayOfWeek.Thursday},
        new DiaRepeticion {Nombre = "V", Dia = DayOfWeek.Friday},
        new DiaRepeticion {Nombre = "S", Dia = DayOfWeek.Saturday},
        new DiaRepeticion {Nombre = "D", Dia = DayOfWeek.Sunday},
    };

    private void IrAFecha(ChangeEventArgs e)
    {
        if(DateTime.TryParse(e.Value?.ToString(), out DateTime fechaSeleccionada))
        {
            int diasHastaLunes = ((int)fechaSeleccionada.DayOfWeek - (int)DayOfWeek.Monday);
            if (diasHastaLunes < 0) diasHastaLunes += 7;

            lunesDeEstaSemana = fechaSeleccionada.AddDays(-diasHastaLunes);
        }
    }
}