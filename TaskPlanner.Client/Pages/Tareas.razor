@page "/tarea"
@using TaskPlanner.Client.Services
@using TaskPlanner.Client.Models
@inject TaskService Service

<h3>Tareas</h3>

<div class="row mb-3">
	<div class="col-md-6">
		<EditForm Model=@nuevaTarea OnValidSubmit=@CrearTarea>
			<div class="form-group">
				<InputText class="form-control" @bind-Value="nuevaTarea.Titulo" placeholder="Título de la tarea"></InputText>
				<InputDate class="form-control" @bind-Value="nuevaTarea.FechaInicio"></InputDate>
				<InputSelect class="form-control" @bind-Value="nuevaTarea.CategoriaId">
					<option value="0">-- Selecciona --</option>
					@if (categorias != null)
					{						
						@foreach (var cat in categorias)
						{
							<option value="@cat.Id">@cat.Nombre</option>
						}
					}										
				</InputSelect>
				<button type="submit" class="btn btn-success">Guardar</button>
			</div>
		</EditForm>
	</div>
</div>

@if (tareas == null)
{
	<p><em>Loading...</em></p>
}
else
{
	<table class=" table table-striped table-hover">
		<thead>
			<tr>
				<td>Título</td>
				<td>Fecha</td>
				<td>Categoría</td>
				<td>Acciones</td>
			</tr>
		</thead>
		<tbody>
			@foreach (var t in tareas)
			{
				<tr>
					<td>@t.Titulo</td>
					<td>@t.FechaInicio.ToShortDateString()</td>
					<td>@t.Categoria?.Nombre</td>
					<td>
						<div class="dropdown">

							<button class="btn btn-link text-dark text-decoration-none"
									type="button"
									data-bs-toggle="dropdown"
									aria-expanded="false">
								&#x22EE;
							</button>

							<ul class="dropdown-menu">

								<li><button class="dropdown-item" type="button">Editar</button></li>

								<li>
									<button class="dropdown-item text-danger"
											type="button"
											@onclick="@(() => Borrar(t.Id))">
										Eliminar
									</button>
								</li>

							</ul>
						</div>
					</td>
				</tr>
			}
		</tbody>
	</table>
}

@code {
	private List<Tarea>? tareas;
	private List<Categoria>? categorias;

	protected override async Task OnInitializedAsync()
	{
		tareas = await Service.GetTareas();

		categorias = await Service.GetCategorias();
	}

	private Tarea nuevaTarea = new Tarea {FechaInicio = DateTime.Today };

	private async Task CrearTarea()
	{
		await Service.SaveTarea(nuevaTarea);

		nuevaTarea = new Tarea();

		tareas = await Service.GetTareas();
	}

	private async Task Borrar(int id)
	{
		await Service.DeleteTarea(id);

		tareas = await Service.GetTareas();
	}

}
